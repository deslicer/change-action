{
  "name": "change-action",
  "version": "1.0.1",
  "private": true,
  "description": "GitHub Action — install deslicer CLI and run deslicer change commands",
  "license": "Apache-2.0",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
